        "$ref": "#/components/schemas/Budget"
      },
      "example": [
        "example_value"
      ]
    },
    "next_cursor": {
      "type": "string",
      "description": "Cursor for the next page.",
      "example": "eyJpZCI6MTIzfQ=="
    },
    "count": {
      "type": "int32",
      "description": "Number of records returned.",
      "example": 100
    }
  }
}